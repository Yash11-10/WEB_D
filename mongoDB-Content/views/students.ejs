<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Data Print</title>
</head>

<body>
    <h1>Data will be there</h1>
    <table border="1">
        <tr>
            <td>Name</td>
            <td>Age</td>
            <td>email</td>
            <td>operation</td>
            <td>Update</td>
        </tr>
        <% result.forEach(result=>{ %>
            <tr>
                <td>
                    <%= result.name %>
                </td>
                <td>
                    <%= result.age %>
                </td>
                <td>
                    <%= result.email %>
                </td>
                <td>
                    <a href="/ui/delete/<%= result._id %>">delete</a>
                </td>
                <td>
                    <a href="/ui/student/<%= result._id %>">Update</a>
                </td>
            </tr>
            <% }) %>

    </table>
</body>

</html>